# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: anthropic (default), openai, litellm
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-5

# ── API Keys ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Blog Backend ─────────────────────────────────────────────────────────────
# Options: filesystem (default), supabase, postgres, wordpress, notion, contentful
BLOG_BACKEND=filesystem

# ── Supabase backend ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_BLOGS_TABLE=blogs

# ── PostgreSQL backend ───────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://user:pass@localhost:5432/blogs

# ── WordPress backend ────────────────────────────────────────────────────────
WP_URL=https://myblog.com
WP_USER=admin
WP_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Notion backend ───────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Contentful backend ───────────────────────────────────────────────────────
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_MGMT_TOKEN=CFPAT-...
CONTENTFUL_ENVIRONMENT=master

# ── Local settings ───────────────────────────────────────────────────────────
BLOGS_DIR=./blogs
BLOG_AUTHOR=Your Team
BLOG_AUTHOR_TITLE=Engineering & Product
BLOG_AUTHOR_IMAGE=https://example.com/avatar.png

# ── Humanizer rules (optional, path to custom YAML) ─────────────────────────
HUMANIZER_RULES=

# ── Legacy (still works, but prefer LLM_MODEL) ──────────────────────────────
CLAUDE_MODEL=claude-opus-4-5
